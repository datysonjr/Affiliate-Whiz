# .env.example
# OpenClaw Affiliate Bot — Environment Variables
# DO NOT COMMIT REAL SECRETS

# --- Core runtime ---
OPENCLAW_MODE=DRY_RUN               # DRY_RUN | SAFE_STAGING | PRODUCTION
OPENCLAW_TIMEZONE=America/New_York
OPENCLAW_DATA_ROOT=./data
OPENCLAW_EXPORTS_DIR=./data/exports
OPENCLAW_LOGS_DIR=./data/logs
OPENCLAW_DB_PATH=./data/db/openclaw.sqlite

# --- Feature gates ---
ALLOW_PUBLISHING=false              # must be true for SAFE_STAGING / PRODUCTION
STAGING_ONLY=true                   # keep true unless explicitly switching to prod
MAX_POSTS_PER_SITE_PER_DAY=3
MAX_SITES_TOUCHED_PER_DAY=2
MAX_TOTAL_POSTS_PER_DAY=10

# --- Concurrency & limits ---
MAX_CONCURRENCY=2
MAX_JOBS_PER_HOUR=30
JOB_RETRY_LIMIT=2
RETRY_BACKOFF_SECONDS=10,60

# --- Logging ---
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                     # json | text
AUDIT_LOG_ENABLED=true
REDACT_SECRETS_IN_LOGS=true

# --- LLM provider (choose one; keep placeholders) ---
LLM_PROVIDER=openai                 # openai | anthropic | local
LLM_MODEL_DEFAULT=                    # e.g. gpt-4.1-mini / claude-3.7-sonnet / local model name
LLM_API_KEY=                         # required if provider is openai/anthropic

# --- WordPress (STAGING) ---
WP_STAGING_BASE_URL=                 # https://staging-example.com
WP_STAGING_USER=
WP_STAGING_APP_PASSWORD=             # WP Application Password (recommended)

# --- WordPress (PRODUCTION) ---
WP_PROD_BASE_URL=                    # https://example.com
WP_PROD_USER=
WP_PROD_APP_PASSWORD=

# --- Analytics (optional; can be blank for v1 DRY_RUN) ---
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
GSC_CREDENTIALS_JSON_PATH=           # path to credentials file (local only)

# --- Affiliate tracking (optional; depends on your networks) ---
AMAZON_ASSOC_TAG=
IMPACT_API_KEY=
CJ_API_KEY=

# --- Notifications (optional but recommended) ---
ALERT_EMAIL_TO=                      # where alerts go
ALERT_EMAIL_FROM=                    # from address (if using an email provider)
EMAIL_PROVIDER=none                  # none | smtp | resend (optional later)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- Proxy (optional; leave off for v1 unless needed) ---
PROXY_ENABLED=false
PROXY_PROVIDER=
PROXY_API_KEY=
